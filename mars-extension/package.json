{
  "name": "mars-extension",
  "displayName": "mars-extension",
  "description": "Runs MIPS code in VSCode using MARS simulator.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:mars-extension.helloWorld",
    "onCommand:mars-extension.runFile"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "mars-extension.helloWorld",
        "title": "Hello World"
      },
      {
        "command": "mars-extension.runFile",
        "title": "Mars: Run Current File"
      }
    ],
    "configuration": {
      "title": "Mars Extension",
      "properties": {
        "mars-extension.marsJarPath": {
          "type": "string",
          "default": "",
          "description": "Absolute path to the MARS jar file."
        },
        "mars-extension.javaPath": {
          "type": "string",
          "default": "java",
          "description": "Path to the Java executable."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.17",
    "@types/vscode": "^1.116.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.7",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}